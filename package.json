    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.18.0",
    "bcrypt": "^5.1.1",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
