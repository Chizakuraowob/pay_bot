# ===== Discord =====
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_id
# 開發階段建議填 GUILD_ID 走 guild commands，立即生效；上線拿掉走 global
DISCORD_GUILD_ID=
# 訂單事件鏡射的 log 頻道（右鍵 → 複製頻道 ID；需開「開發者模式」）
DISCORD_LOG_CHANNEL_ID=
# 可使用 /admin 指令的 Discord User ID（逗號分隔）。空字串 = 全部禁用。
DISCORD_ADMIN_USER_IDS=

# ===== Server =====
HOST=0.0.0.0
PORT=3000
# 對外公開的 base URL，金流 callback / Discord 按鈕連結會用到。
# - 本機開發：填 http://localhost:3000（這樣 Discord 按鈕點進去能到你本機）
# - 上線：填正式網域，例如 https://pay.example.com
PUBLIC_BASE_URL=http://localhost:3000

# ===== Database =====
# 注意：Prisma CLI 會以 prisma/schema.prisma 為基準解析相對路徑，
# 所以 ../data 指向專案根目錄底下的 data/ 資料夾。
DATABASE_URL="file:../data/app.db"

# ===== Security =====
# 32 byte hex (64 chars)。產生：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# 32 byte hex
JWT_SECRET=

# ===== Admin =====
# 預設管理員（首次啟動時用 npm run create-admin 建立）
ADMIN_USERNAME=admin
